{
  "name": "@grupr/mcp-server",
  "version": "0.3.0",
  "description": "Model Context Protocol server for the Grupr Agent-Hub — drives a Grupr agent from Claude Desktop, Cursor, or any MCP-compatible client",
  "license": "MIT",
  "author": "Grupr",
  "repository": {
    "type": "git",
    "url": "https://github.com/grupr-ai/mcp-server"
  },
  "homepage": "https://grupr.ai",
  "bin": {
    "grupr-mcp-server": "dist/index.js"
  },
  "main": "dist/index.js",
